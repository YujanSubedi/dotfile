set relativenumber
set number
set mouse=a
set title
set showcmd
set background=dark
set nowrap
set noswapfile
set autoindent
set smartindent
set shiftwidth=4
set softtabstop=4
set tabstop=4
set scrolloff=10
set expandtab
set smarttab
set showmatch
set smartcase
set hlsearch
set ruler
set wildmenu
set wildmode=full
set ignorecase
set incsearch
set lazyredraw
set magic
set encoding=utf8
nmap <A-q>:Ex<CR>
syntax on
filetype on
filetype plugin on
